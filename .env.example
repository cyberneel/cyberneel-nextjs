# ----- Content Studio (/admin) -----
# These only need to be set on the deployed (Vercel) environment. In local
# `next dev` the studio is unlocked and writes straight to the data/ folder.

# Password for the /admin login screen (production only).
ADMIN_SECRET=

# Fine-grained GitHub PAT with Read/Write access to "Contents" and
# "Pull requests" on the cyberneel-nextjs repo. Used to commit posts in prod.
GITHUB_TOKEN=

# Optional overrides (defaults shown):
# GITHUB_REPO=cyberneel/cyberneel-nextjs
# GITHUB_DEFAULT_BRANCH=main

# Set to 1 to exercise the production GitHub/PR write path from local dev.
# STUDIO_FORCE_GITHUB=1

# ----- Existing site config (Contentful / contact form) -----
# CONTENTFUL_SPACE_ID=
# CONTENTFUL_ACCESS_TOKEN=
# NEXT_PUBLIC_GOOGLE_FORM_URL=
# NEXT_PUBLIC_GOOGLE_FORM_ENTRY_NAME=
# NEXT_PUBLIC_GOOGLE_FORM_ENTRY_EMAIL=
# NEXT_PUBLIC_GOOGLE_FORM_ENTRY_MESSAGE=
